generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Route {
  id          Int      @id @default(autoincrement())
  name        String
  distance    Float
  duration    Int
  difficulty  String
  category    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
